# Elfant database connection string.
# For local dev via k3s tunnel (scripts/db-tunnel.sh):
ELFANT_DATABASE_URL="postgresql://user:pass@localhost:5432/dev_elfant"
# When running the app inside Docker Compose, use host.docker.internal:
# ELFANT_DATABASE_URL="postgresql://user:pass@host.docker.internal:5432/dev_elfant"
